{"module":"Whiteboard","version":"","cmdlets":{"Get-OriginalFluidWhiteboards":{"syntax":"Get-OriginalFluidWhiteboards [-UserId] <Guid> [[-ConnectMgGraph] <String>] [[-ContinuationToken] <String>]\n [-ForceAuthPrompt] [[-IncrementalRunName] <String>] [<CommonParameters>]","examples":["PS C:\\>Get-OriginalFluidWhiteboards -UserId 00000000-0000-0000-0000-000000000001"]},"Get-OriginalFluidWhiteboardsForTenant":{"syntax":"Get-OriginalFluidWhiteboardsForTenant [[-IncrementalRunName] <String>] [-ForceAuthPrompt]\n [<CommonParameters>]","examples":["PS C:\\>Get-OriginalFluidWhiteboardsForTenant","Get all user's originally created fluid whiteboards in that tenant and incrementally creates file\n\"WhiteboardsOriginalFluid-$IncrementalRunName.txt\" with all users whiteboards provided admin has\naccess to all those users oneDrive for which it is intended to get whiteboards."]},"Get-WhiteboardOwners":{"syntax":"Get-WhiteboardOwners [-Geography] <String> [[-ContinuationToken] <String>] [-ForceAuthPrompt]\n [<CommonParameters>]","examples":["PS C:\\>Get-WhiteboardOwners -Geography Europe"]},"Get-WhiteboardsForTenant":{"syntax":"Get-WhiteboardsForTenant [-Geography] <String> [[-IncrementalRunName] <String>] [-ForceAuthPrompt]\n [<CommonParameters>]","examples":["Get-WhiteboardsForTenant -Geography Europe"]},"Get-WhiteboardsForTenantMigrated":{"syntax":"Get-WhiteboardsForTenantMigrated [[-IncrementalRunName] <String>] [-ForceAuthPrompt]\n [<CommonParameters>]","examples":["Get-WhiteboardsForTenantMigrated","Get all user's migrated whiteboards in that tenant and incrementally creates file\n\"WhiteboardsMigrated-$IncrementalRunName.txt\" with all users whiteboards provided admin has access\nto all those users oneDrive."]},"Get-WhiteboardsMigrated":{"syntax":"Get-WhiteboardsMigrated [-UserId] <Guid> [[-ConnectMgGraph] <String>] [[-ContinuationToken] <String>]\n [-ForceAuthPrompt] [[-IncrementalRunName] <String>] [<CommonParameters>]","examples":["Get-WhiteboardsMigrated -UserId e2ff85a